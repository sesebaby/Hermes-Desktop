<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <EnableHarmony>true</EnableHarmony>
    <GenerateDocumentation>true</GenerateDocumentation>
    <HasTranslations>true</HasTranslations>
  </PropertyGroup>
  <Import Project="$(SolutionDir)common.targets" />

  <PropertyGroup>
    <Name>SpaceCore</Name>
    <UniqueId>spacechase0.$(AssemblyName)</UniqueId>
    <Description>The space-iest of cores. (Framework mod)</Description>
    <Version>1.29.0</Version>
    <UpdateKeys>Nexus:1348</UpdateKeys>
    <Version_AppendConfiguration>false</Version_AppendConfiguration> <!-- Otherwise mods get confused about having 1.13.0-Debug, but needing 1.13.0 or newer -->

    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <DefineConstants>TRACE</DefineConstants>
  </PropertyGroup>
  <PropertyGroup>
    <DefineConstants>IS_SPACECORE</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Reflection.Metadata" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <SMAPIDependency Include="Pathoschild.ContentPatcher" Required="false" />
  </ItemGroup>

  <ItemGroup>
    <None Update="docs\README.md">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
