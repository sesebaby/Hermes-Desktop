<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <EnableHarmony>true</EnableHarmony>
    <RequireSpaceCore>true</RequireSpaceCore>
    <HasTranslations>true</HasTranslations>
  </PropertyGroup>
  <Import Project="$(SolutionDir)common.targets" />

  <PropertyGroup>
    <Name>The Third Dimension</Name>
    <Description>Stardew Valley... in THREE DEEEEE. (Incompatibility with other mods almost guarenteed.)</Description>
    <Version>0.1.0</Version>

    <BundleExtraAssemblies>ThirdParty</BundleExtraAssemblies>
    <AllowUnsafeBlocks>True</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="OpenVR.NET" Version="0.8.5" IncludeAssets="all" GeneratePathProperty="true" />
    <None Include="$(PkgOpenVR_Net)/content/openvr_api.dll" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <Target Name="CheckForOpenvrApi" BeforeTargets="Build">
    <Error Condition=" !Exists( '$(PkgOpenVR_Net)/content/openvr_api.dll' ) " Text="OpenVR API didn't exist in $(PkgOpenVR_Net)" />
  </Target>
  
  <ItemGroup>
    <Publicize Include="MonoGame.Framework" IncludeVirtualMembers="false" />
    <Publicize Include="xTile" IncludeVirtualMemebers="false" />
  </ItemGroup>
  
  <ItemGroup>
    <!-- We're doing this kinda weird since publicizer doesn't seem to work with ProjectReference -->
    <ProjectReference Include="$(SolutionDir)_external\MonoScene\src\MonoScene.Pipeline.GLTF\MonoScene.Pipeline.GLTF.csproj" ReferenceOutputAssembly="false" />
    <ProjectReference Include="$(SolutionDir)_external\MonoScene\src\MonoScene.Runtime.Scene3D\MonoScene.Runtime.Scene3D.csproj" ReferenceOutputAssembly="false" />

    <Publicize Include="MonoScene.Runtime.Model3D" IncludeVirtualMembers="false" />
    <Publicize Include="MonoScene.Runtime.Scene3D" IncludeVirtualMembers="false" />

    <ProjectReference Include="$(SolutionDir)_external\GJKEPA_Project\GJKEPA_Project.csproj" />
    
    <ProjectReference Include="$(SolutionDir)_external\MLEM\MLEM\MLEM.csproj" />
    <ProjectReference Include="$(SolutionDir)_external\MLEM\MLEM.Ui\MLEM.Ui.csproj" />

    <Reference Include="TMXTile">
      <HintPath>$(GamePath)/smapi-internal/TMXTile.dll</HintPath>
    </Reference>

    <PackageReference Include="SharpGLTF.Core" Version="1.0.0-alpha0029" />
    <Reference Include="MonoGamePolyfill.dll">
      <HintPath>$(SolutionDir)_external_helpers\MonoGamePolyfill\bin\$(Configuration)\net6.0\MonoGamePolyfill.dll</HintPath>
    </Reference>
    <Reference Include="MonoScene.Pipeline.GLTF.dll">
      <HintPath>$(SolutionDir)_external\MonoScene\src\MonoScene.Pipeline.GLTF\bin\$(Configuration)\net6.0\MonoScene.Pipeline.GLTF.dll</HintPath>
    </Reference>
    <Reference Include="MonoScene.Runtime.Content.dll">
      <HintPath>$(SolutionDir)_external\MonoScene\src\MonoScene.Runtime.Content\bin\$(Configuration)\net6.0\MonoScene.Runtime.Content.dll</HintPath>
    </Reference>
    <Reference Include="MonoScene.Runtime.Effects.Classic.dll">
      <HintPath>$(SolutionDir)_external\MonoScene\src\MonoScene.Runtime.Effects.Classic\bin\$(Configuration)\net6.0\MonoScene.Runtime.Effects.Classic.dll</HintPath>
    </Reference>
    <Reference Include="MonoScene.Runtime.Effects.PBR.dll">
      <HintPath>$(SolutionDir)_external\MonoScene\src\MonoScene.Runtime.Effects.PBR\bin\$(Configuration)\net6.0\MonoScene.Runtime.Effects.PBR.dll</HintPath>
    </Reference>
    <Reference Include="MonoScene.Runtime.Model3D.dll">
      <HintPath>$(SolutionDir)_external\MonoScene\src\MonoScene.Runtime.Model3D\bin\$(Configuration)\net6.0\MonoScene.Runtime.Model3D.dll</HintPath>
    </Reference>
    <Reference Include="MonoScene.Runtime.Scene3D.dll">
      <HintPath>$(SolutionDir)_external\MonoScene\src\MonoScene.Runtime.Scene3D\bin\$(Configuration)\net6.0\MonoScene.Runtime.Scene3D.dll</HintPath>
    </Reference>
  </ItemGroup>
</Project>
