<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HermesDesktop.Views.Panels.TaskPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:panels="using:HermesDesktop.Views.Panels">

    <Grid RowDefinitions="Auto,Auto,*,Auto,*">
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock
                x:Uid="TaskPanelTitle"
                Style="{StaticResource SectionTitleTextStyle}"/>
            <Button
                x:Name="RefreshBtn"
                x:Uid="TaskPanelRefreshButton"
                AutomationProperties.AutomationId="TaskPanelRefreshButton"
                Click="Refresh_Click"
                CornerRadius="6"
                Padding="6,2"
                Background="Transparent"
                Foreground="{StaticResource AppTextSecondaryBrush}"/>
        </StackPanel>

        <TextBlock
            Grid.Row="1"
            x:Uid="TaskPanelLiveTitle"
            Margin="0,0,0,4"
            FontSize="11"
            FontWeight="SemiBold"
            Foreground="{StaticResource AppTextSecondaryBrush}"/>

        <TextBlock Grid.Row="2" x:Name="EmptyState" x:Uid="TaskPanelEmptyState" Visibility="Collapsed"
                   Foreground="{StaticResource AppTextSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" FontSize="13" Opacity="0.7"/>

        <ListView
            Grid.Row="2"
            x:Name="TaskList"
            x:Uid="TaskPanelLiveList"
            Background="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="panels:TaskListItem">
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,4">
                        <Border Grid.Column="0" Background="{x:Bind StatusColor, Mode=OneWay}" CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind StatusLabel, Mode=OneWay}" FontSize="10" Foreground="White"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{x:Bind Description, Mode=OneWay}" FontSize="13"
                                       Foreground="{x:Bind DescriptionBrush, Mode=OneWay}" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind PriorityLabel, Mode=OneWay}" FontSize="11"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock
            Grid.Row="3"
            x:Uid="TaskPanelArchiveTitle"
            Margin="0,12,0,4"
            FontSize="11"
            FontWeight="SemiBold"
            Foreground="{StaticResource AppTextSecondaryBrush}"/>

        <TextBlock
            Grid.Row="4"
            x:Name="ArchiveEmptyState"
            x:Uid="TaskPanelArchiveEmptyState"
            Visibility="Collapsed"
            Foreground="{StaticResource AppTextSecondaryBrush}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            TextAlignment="Center"
            FontSize="12"
            Opacity="0.7"/>

        <ListView
            Grid.Row="4"
            x:Name="ArchiveList"
            x:Uid="TaskPanelArchiveList"
            Background="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="panels:TaskArchiveListItem">
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,4">
                        <Border Grid.Column="0" Background="{x:Bind StatusColor, Mode=OneWay}" CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind StatusLabel, Mode=OneWay}" FontSize="10" Foreground="White"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{x:Bind Description, Mode=OneWay}" FontSize="12"
                                       Foreground="{x:Bind DescriptionBrush, Mode=OneWay}" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind TurnLabel, Mode=OneWay}" FontSize="11"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind SummaryLabel, Mode=OneWay}" FontSize="11"
                                           Foreground="{x:Bind SummaryBrush, Mode=OneWay}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
