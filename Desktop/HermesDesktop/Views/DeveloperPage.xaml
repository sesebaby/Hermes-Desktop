<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.DeveloperPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:HermesDesktop.Models"
    xmlns:runtime="using:Hermes.Agent.Runtime"
    Background="Transparent"
    Loaded="OnPageLoaded"
    NavigationCacheMode="Required"
    mc:Ignorable="d">
    <Grid Padding="32,24,32,40" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock
                    x:Uid="DeveloperPageEyebrow"
                    Style="{StaticResource PageEyebrowTextStyle}" />
                <TextBlock
                    x:Uid="DeveloperPageTitle"
                    Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock
                    x:Uid="DeveloperPageSubtitle"
                    Style="{StaticResource BodySecondaryTextStyle}"
                    MaxWidth="900" />
            </StackPanel>
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Bottom">
                <Button
                    x:Name="DeveloperRefreshButton"
                    x:Uid="DeveloperRefreshButton"
                    AutomationProperties.AutomationId="DeveloperRefreshButton"
                    AccessKey="R"
                    Click="Refresh_Click"
                    Background="{StaticResource AppAccentGradientBrush}"
                    Foreground="#16110D"
                    Padding="14,8" />
                <Button
                    x:Name="DeveloperOpenRuntimeDirectoryButton"
                    x:Uid="DeveloperOpenRuntimeDirectoryButton"
                    AutomationProperties.AutomationId="DeveloperOpenRuntimeDirectoryButton"
                    Click="OpenRuntimeDirectory_Click"
                    Background="{StaticResource AppInsetBrush}"
                    BorderBrush="{StaticResource AppStrokeBrush}"
                    Foreground="White"
                    Padding="14,8" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource SurfaceCardStyle}">
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2">
                    <TextBlock
                        x:Uid="DeveloperRuntimeCountLabel"
                        Style="{StaticResource LabelTextStyle}" />
                    <TextBlock
                        x:Name="RuntimeCountText"
                        Text="0"
                        Style="{StaticResource MetricValueTextStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock
                        x:Uid="DeveloperBridgeLabel"
                        Style="{StaticResource LabelTextStyle}" />
                    <TextBlock
                        x:Name="BridgeHealthText"
                        Text="-"
                        TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="2">
                    <TextBlock
                        x:Uid="DeveloperMainChannelLabel"
                        Style="{StaticResource LabelTextStyle}" />
                    <TextBlock
                        x:Name="ChannelText"
                        Text="stardew_autonomy / delegation"
                        FontFamily="Consolas"
                        FontSize="12"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="3" Spacing="2">
                    <TextBlock
                        x:Uid="DeveloperLastErrorLabel"
                        Style="{StaticResource LabelTextStyle}" />
                    <TextBlock
                        x:Name="LastErrorText"
                        Text="-"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource SurfaceCardStyle}" Padding="0">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Padding="16,14,16,4" Spacing="3">
                        <TextBlock
                            x:Uid="DeveloperNpcListTitle"
                            Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock
                            x:Uid="DeveloperNpcListSubtitle"
                            Style="{StaticResource BodySecondaryTextStyle}"
                            FontSize="12" />
                    </StackPanel>
                    <ListView
                        x:Name="NpcList"
                        x:Uid="DeveloperNpcList"
                        Grid.Row="1"
                        Background="Transparent"
                        IsItemClickEnabled="True"
                        ItemClick="NpcList_ItemClick"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:NpcRuntimeItem">
                                <StackPanel Margin="8,8" Spacing="3">
                                    <TextBlock
                                        Text="{x:Bind DisplayName}"
                                        FontSize="14"
                                        FontWeight="SemiBold" />
                                    <TextBlock
                                        Text="{x:Bind NpcId}"
                                        FontFamily="Consolas"
                                        FontSize="12"
                                        Foreground="{StaticResource AppTextSecondaryBrush}" />
                                    <TextBlock
                                        Text="{x:Bind State}"
                                        FontSize="12"
                                        Foreground="{StaticResource AppTextSecondaryBrush}" />
                                    <TextBlock
                                        Text="{x:Bind TaskSummary}"
                                        FontSize="12"
                                        Foreground="{StaticResource AppTextSecondaryBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Grid Grid.Column="1" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="3*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource SurfaceCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock
                                x:Uid="DeveloperSelectedNpcLabel"
                                Style="{StaticResource LabelTextStyle}" />
                            <TextBlock
                                x:Name="SelectedNpcText"
                                Text="-"
                                FontSize="18"
                                FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock
                                x:Uid="DeveloperSessionLabel"
                                Style="{StaticResource LabelTextStyle}" />
                            <TextBlock
                                x:Name="SessionIdText"
                                Text="-"
                                FontFamily="Consolas"
                                FontSize="12"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock
                                x:Uid="DeveloperTraceLabel"
                                Style="{StaticResource LabelTextStyle}" />
                            <TextBlock
                                x:Name="TraceIdText"
                                Text="-"
                                FontFamily="Consolas"
                                FontSize="12"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="2">
                            <TextBlock
                                x:Uid="DeveloperStateLabel"
                                Style="{StaticResource LabelTextStyle}" />
                            <TextBlock
                                x:Name="NpcStateText"
                                Text="-"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="DeveloperControlledDebugTitle"
                                Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock
                                x:Uid="DeveloperControlledDebugDescription"
                                Grid.Row="1"
                                Style="{StaticResource BodySecondaryTextStyle}"
                                FontSize="12"
                                TextWrapping="Wrap" />
                            <Grid
                                Grid.Row="2"
                                ColumnSpacing="8"
                                RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Button
                                    x:Name="DebugRepositionButton"
                                    x:Uid="DeveloperDebugRepositionButton"
                                    AutomationProperties.AutomationId="DeveloperDebugRepositionButton"
                                    Click="DebugReposition_Click"
                                    Background="{StaticResource AppAccentGradientBrush}"
                                    Foreground="#16110D"
                                    Padding="10,6" />
                                <Button
                                    x:Name="DebugTickButton"
                                    x:Uid="DeveloperDebugTickButton"
                                    Grid.Column="1"
                                    AutomationProperties.AutomationId="DeveloperDebugTickButton"
                                    Click="DebugTick_Click"
                                    Background="{StaticResource AppInsetBrush}"
                                    BorderBrush="{StaticResource AppStrokeBrush}"
                                    Foreground="White"
                                    Padding="10,6" />
                                <Button
                                    x:Name="DebugSpeakButton"
                                    x:Uid="DeveloperDebugSpeakButton"
                                    Grid.Row="1"
                                    AutomationProperties.AutomationId="DeveloperDebugSpeakButton"
                                    Click="DebugSpeak_Click"
                                    Background="{StaticResource AppInsetBrush}"
                                    BorderBrush="{StaticResource AppStrokeBrush}"
                                    Foreground="White"
                                    Padding="10,6" />
                                <Button
                                    x:Name="DebugBeachRouteButton"
                                    x:Uid="DeveloperDebugBeachRouteButton"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    AutomationProperties.AutomationId="DeveloperDebugBeachRouteButton"
                                    Click="DebugBeachRoute_Click"
                                    Background="{StaticResource AppInsetBrush}"
                                    BorderBrush="{StaticResource AppStrokeBrush}"
                                    Foreground="White"
                                    Padding="10,6" />
                            </Grid>
                            <TextBlock
                                x:Name="DebugActionStatusText"
                                x:Uid="DeveloperDebugActionStatusInitial"
                                Grid.Row="3"
                                FontSize="12"
                                Foreground="{StaticResource AppTextSecondaryBrush}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                x:Name="DebugActionResultText"
                                x:Uid="DeveloperDebugActionResultInitial"
                                Grid.Row="4"
                                FontSize="12"
                                Foreground="{StaticResource AppTextSecondaryBrush}"
                                TextWrapping="Wrap"
                                AutomationProperties.LiveSetting="Polite" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="DeveloperTraceFilterTitle"
                                Style="{StaticResource SectionTitleTextStyle}" />
                            <Grid
                                Grid.Row="1"
                                ColumnSpacing="8"
                                RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBox
                                    x:Name="TraceIdFilterBox"
                                    x:Uid="DeveloperTraceIdFilterBox"
                                    AutomationProperties.AutomationId="DeveloperTraceIdFilterBox"
                                    FontSize="12" />
                                <TextBox
                                    x:Name="EventTypeFilterBox"
                                    x:Uid="DeveloperEventTypeFilterBox"
                                    Grid.Column="1"
                                    AutomationProperties.AutomationId="DeveloperEventTypeFilterBox"
                                    FontSize="12" />
                                <TextBox
                                    x:Name="CommandIdFilterBox"
                                    x:Uid="DeveloperCommandIdFilterBox"
                                    Grid.Column="2"
                                    AutomationProperties.AutomationId="DeveloperCommandIdFilterBox"
                                    FontSize="12" />
                                <TextBox
                                    x:Name="ToolNameFilterBox"
                                    x:Uid="DeveloperToolNameFilterBox"
                                    Grid.Row="1"
                                    AutomationProperties.AutomationId="DeveloperToolNameFilterBox"
                                    FontSize="12" />
                                <TextBox
                                    x:Name="ErrorCodeFilterBox"
                                    x:Uid="DeveloperErrorCodeFilterBox"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    AutomationProperties.AutomationId="DeveloperErrorCodeFilterBox"
                                    FontSize="12" />
                                <TextBox
                                    x:Name="KeywordFilterBox"
                                    x:Uid="DeveloperKeywordFilterBox"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    AutomationProperties.AutomationId="DeveloperKeywordFilterBox"
                                    FontSize="12" />
                            </Grid>
                            <StackPanel
                                Grid.Row="2"
                                Orientation="Horizontal"
                                Spacing="8">
                                <Button
                                    x:Name="ApplyTraceFilterButton"
                                    x:Uid="DeveloperApplyTraceFilterButton"
                                    AutomationProperties.AutomationId="DeveloperApplyTraceFilterButton"
                                    Click="ApplyTraceFilter_Click"
                                    Background="{StaticResource AppAccentGradientBrush}"
                                    Foreground="#16110D"
                                    Padding="10,6" />
                                <Button
                                    x:Name="ClearTraceFilterButton"
                                    x:Uid="DeveloperClearTraceFilterButton"
                                    AutomationProperties.AutomationId="DeveloperClearTraceFilterButton"
                                    Click="ClearTraceFilter_Click"
                                    Background="{StaticResource AppInsetBrush}"
                                    BorderBrush="{StaticResource AppStrokeBrush}"
                                    Foreground="White"
                                    Padding="10,6" />
                                <Button
                                    x:Name="ExportDiagnosticsButton"
                                    x:Uid="DeveloperExportDiagnosticsButton"
                                    AutomationProperties.AutomationId="DeveloperExportDiagnosticsButton"
                                    Click="ExportDiagnostics_Click"
                                    Background="{StaticResource AppInsetBrush}"
                                    BorderBrush="{StaticResource AppStrokeBrush}"
                                    Foreground="White"
                                    Padding="10,6" />
                            </StackPanel>
                            <TextBlock
                                x:Name="DiagnosticsExportText"
                                x:Uid="DeveloperDiagnosticsExportInitial"
                                Grid.Row="3"
                                FontSize="12"
                                Foreground="{StaticResource AppTextSecondaryBrush}"
                                TextWrapping="Wrap"
                                AutomationProperties.LiveSetting="Polite" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="DeveloperDocumentsTitle"
                                Style="{StaticResource SectionTitleTextStyle}" />
                            <ListView
                                x:Name="DocumentList"
                                x:Uid="DeveloperDocumentList"
                                Grid.Row="1"
                                Background="Transparent"
                                SelectionMode="Single"
                                SelectionChanged="DocumentList_SelectionChanged">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="runtime:NpcDeveloperDocument">
                                        <StackPanel Margin="0,6" Spacing="2">
                                            <TextBlock
                                                Text="{x:Bind Name}"
                                                FontFamily="Consolas"
                                                FontWeight="SemiBold" />
                                            <TextBlock
                                                Text="{x:Bind Status}"
                                                FontSize="12"
                                                Foreground="{StaticResource AppTextSecondaryBrush}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="DeveloperDocumentPreviewTitle"
                                Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock
                                x:Name="DocumentPathText"
                                Grid.Row="1"
                                FontFamily="Consolas"
                                FontSize="11"
                                Foreground="{StaticResource AppTextSecondaryBrush}"
                                TextTrimming="CharacterEllipsis" />
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <TextBlock
                                    x:Name="DocumentPreviewText"
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    TextWrapping="Wrap"
                                    Text="-" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="3" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="DeveloperTimelineTitle"
                                Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock
                                x:Name="TraceEmptyText"
                                Grid.Row="1"
                                Foreground="{StaticResource AppTextSecondaryBrush}"
                                TextWrapping="Wrap" />
                            <ListView
                                x:Name="TraceList"
                                x:Uid="DeveloperTraceList"
                                Grid.Row="2"
                                Background="Transparent"
                                SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="runtime:NpcDeveloperTraceEvent">
                                        <StackPanel Margin="0,6" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock
                                                    Text="{x:Bind TimestampText}"
                                                    FontFamily="Consolas"
                                                    FontSize="12"
                                                    Foreground="{StaticResource AppTextSecondaryBrush}" />
                                                <TextBlock
                                                    Text="{x:Bind Kind}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource AppAccentTextBrush}" />
                                            </StackPanel>
                                            <TextBlock
                                                Text="{x:Bind Result}"
                                                FontSize="12"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                Text="{x:Bind Target}"
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Foreground="{StaticResource AppTextSecondaryBrush}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="DeveloperDetailsTitle"
                                Style="{StaticResource SectionTitleTextStyle}" />
                            <StackPanel
                                Grid.Row="1"
                                Orientation="Horizontal"
                                Spacing="6">
                                <Button
                                    x:Name="DetailModelButton"
                                    x:Uid="DeveloperDetailModelButton"
                                    AutomationProperties.AutomationId="DeveloperDetailModelButton"
                                    Click="DetailTab_Click"
                                    Tag="model"
                                    Background="{StaticResource AppAccentGradientBrush}"
                                    Foreground="#16110D" />
                                <Button
                                    x:Name="DetailToolButton"
                                    x:Uid="DeveloperDetailToolButton"
                                    AutomationProperties.AutomationId="DeveloperDetailToolButton"
                                    Click="DetailTab_Click"
                                    Tag="tools"
                                    Background="{StaticResource AppInsetBrush}"
                                    BorderBrush="{StaticResource AppStrokeBrush}"
                                    Foreground="{StaticResource AppTextSecondaryBrush}" />
                                <Button
                                    x:Name="DetailDelegationButton"
                                    x:Uid="DeveloperDetailDelegationButton"
                                    AutomationProperties.AutomationId="DeveloperDetailDelegationButton"
                                    Click="DetailTab_Click"
                                    Tag="delegation"
                                    Background="{StaticResource AppInsetBrush}"
                                    BorderBrush="{StaticResource AppStrokeBrush}"
                                    Foreground="{StaticResource AppTextSecondaryBrush}" />
                                <Button
                                    x:Name="DetailTodoButton"
                                    x:Uid="DeveloperDetailTodoButton"
                                    AutomationProperties.AutomationId="DeveloperDetailTodoButton"
                                    Click="DetailTab_Click"
                                    Tag="todos"
                                    Background="{StaticResource AppInsetBrush}"
                                    BorderBrush="{StaticResource AppStrokeBrush}"
                                    Foreground="{StaticResource AppTextSecondaryBrush}" />
                                <Button
                                    x:Name="DetailLogsButton"
                                    x:Uid="DeveloperDetailLogsButton"
                                    AutomationProperties.AutomationId="DeveloperDetailLogsButton"
                                    Click="DetailTab_Click"
                                    Tag="logs"
                                    Background="{StaticResource AppInsetBrush}"
                                    BorderBrush="{StaticResource AppStrokeBrush}"
                                    Foreground="{StaticResource AppTextSecondaryBrush}" />
                                <Button
                                    x:Name="DetailContextButton"
                                    x:Uid="DeveloperDetailContextButton"
                                    AutomationProperties.AutomationId="DeveloperDetailContextButton"
                                    Click="DetailTab_Click"
                                    Tag="context"
                                    Background="{StaticResource AppInsetBrush}"
                                    BorderBrush="{StaticResource AppStrokeBrush}"
                                    Foreground="{StaticResource AppTextSecondaryBrush}" />
                            </StackPanel>

                            <Grid Grid.Row="2">
                                <ListView
                                    x:Name="ModelReplyList"
                                    x:Uid="DeveloperModelReplyList"
                                    Background="Transparent"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="runtime:NpcDeveloperModelReply">
                                            <StackPanel Margin="0,8" Spacing="5">
                                                <TextBlock
                                                    Text="{x:Bind TimestampText}"
                                                    FontFamily="Consolas"
                                                    FontSize="11"
                                                    Foreground="{StaticResource AppTextSecondaryBrush}" />
                                                <TextBlock
                                                    Text="{x:Bind Content}"
                                                    TextWrapping="Wrap" />
                                                <TextBlock
                                                    Text="{x:Bind Reasoning}"
                                                    FontSize="12"
                                                    Foreground="{StaticResource AppTextSecondaryBrush}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <ListView
                                    x:Name="ToolCallList"
                                    x:Uid="DeveloperToolCallList"
                                    Background="Transparent"
                                    SelectionMode="None"
                                    Visibility="Collapsed">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="runtime:NpcDeveloperToolCall">
                                            <StackPanel Margin="0,8" Spacing="5">
                                                <TextBlock
                                                    Text="{x:Bind Name}"
                                                    FontFamily="Consolas"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource AppAccentTextBrush}" />
                                                <TextBlock
                                                    Text="{x:Bind Id}"
                                                    FontFamily="Consolas"
                                                    FontSize="11"
                                                    Foreground="{StaticResource AppTextSecondaryBrush}" />
                                                <TextBlock
                                                    Text="{x:Bind Arguments}"
                                                    FontFamily="Consolas"
                                                    FontSize="12"
                                                    TextWrapping="Wrap" />
                                                <TextBlock
                                                    Text="{x:Bind Result}"
                                                    FontFamily="Consolas"
                                                    FontSize="12"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <ListView
                                    x:Name="DelegationList"
                                    x:Uid="DeveloperDelegationList"
                                    Background="Transparent"
                                    SelectionMode="None"
                                    Visibility="Collapsed">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="runtime:NpcDeveloperDelegation">
                                            <StackPanel Margin="0,8" Spacing="5">
                                                <TextBlock
                                                    Text="{x:Bind ToolCallId}"
                                                    FontFamily="Consolas"
                                                    FontSize="11"
                                                    Foreground="{StaticResource AppTextSecondaryBrush}" />
                                                <TextBlock
                                                    Text="{x:Bind Request}"
                                                    FontFamily="Consolas"
                                                    FontSize="12"
                                                    TextWrapping="Wrap" />
                                                <TextBlock
                                                    Text="{x:Bind Result}"
                                                    FontFamily="Consolas"
                                                    FontSize="12"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <ListView
                                    x:Name="TodoList"
                                    x:Uid="DeveloperTodoList"
                                    Background="Transparent"
                                    SelectionMode="None"
                                    Visibility="Collapsed">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="runtime:NpcDeveloperTodo">
                                            <StackPanel Margin="0,8" Spacing="3">
                                                <TextBlock
                                                    Text="{x:Bind Content}"
                                                    FontWeight="SemiBold"
                                                    TextWrapping="Wrap" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock
                                                        Text="{x:Bind Id}"
                                                        FontFamily="Consolas"
                                                        FontSize="11"
                                                        Foreground="{StaticResource AppTextSecondaryBrush}" />
                                                    <TextBlock
                                                        Text="{x:Bind Status}"
                                                        FontFamily="Consolas"
                                                        FontSize="11"
                                                        Foreground="{StaticResource AppTextSecondaryBrush}" />
                                                </StackPanel>
                                                <TextBlock
                                                    Text="{x:Bind Reason}"
                                                    FontSize="12"
                                                    Foreground="{StaticResource AppTextSecondaryBrush}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <ScrollViewer
                                    x:Name="LogsPanel"
                                    Visibility="Collapsed"
                                    VerticalScrollBarVisibility="Auto">
                                    <StackPanel Spacing="8">
                                        <TextBlock
                                            x:Name="RuntimePathText"
                                            FontFamily="Consolas"
                                            FontSize="12"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            x:Name="RuntimeLogPathText"
                                            FontFamily="Consolas"
                                            FontSize="12"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            x:Name="TraceDiagnosticsText"
                                            FontFamily="Consolas"
                                            FontSize="12"
                                            Foreground="{StaticResource AppTextSecondaryBrush}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </ScrollViewer>
                                <ListView
                                    x:Name="ContextBlockList"
                                    x:Uid="DeveloperContextBlockList"
                                    Background="Transparent"
                                    SelectionMode="None"
                                    Visibility="Collapsed">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="runtime:NpcDeveloperContextBlock">
                                            <StackPanel Margin="0,8" Spacing="5">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock
                                                        Text="{x:Bind Name}"
                                                        FontFamily="Consolas"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource AppAccentTextBrush}" />
                                                    <TextBlock
                                                        Text="{x:Bind Hash}"
                                                        FontFamily="Consolas"
                                                        FontSize="11"
                                                        Foreground="{StaticResource AppTextSecondaryBrush}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock
                                                        x:Uid="DeveloperContextCharsBeforeLabel"
                                                        FontSize="11"
                                                        Foreground="{StaticResource AppTextSecondaryBrush}" />
                                                    <TextBlock
                                                        Text="{x:Bind CharactersBefore}"
                                                        FontFamily="Consolas"
                                                        FontSize="11"
                                                        Foreground="{StaticResource AppTextSecondaryBrush}" />
                                                    <TextBlock
                                                        x:Uid="DeveloperContextCharsAfterLabel"
                                                        FontSize="11"
                                                        Foreground="{StaticResource AppTextSecondaryBrush}" />
                                                    <TextBlock
                                                        Text="{x:Bind CharactersAfter}"
                                                        FontFamily="Consolas"
                                                        FontSize="11"
                                                        Foreground="{StaticResource AppTextSecondaryBrush}" />
                                                    <TextBlock
                                                        x:Uid="DeveloperContextTokensLabel"
                                                        FontSize="11"
                                                        Foreground="{StaticResource AppTextSecondaryBrush}" />
                                                    <TextBlock
                                                        Text="{x:Bind EstimatedTokens}"
                                                        FontFamily="Consolas"
                                                        FontSize="11"
                                                        Foreground="{StaticResource AppTextSecondaryBrush}" />
                                                    <TextBlock
                                                        x:Uid="DeveloperContextTrimmedLabel"
                                                        FontSize="11"
                                                        Foreground="{StaticResource AppTextSecondaryBrush}" />
                                                    <TextBlock
                                                        Text="{x:Bind Trimmed}"
                                                        FontFamily="Consolas"
                                                        FontSize="11"
                                                        Foreground="{StaticResource AppTextSecondaryBrush}" />
                                                </StackPanel>
                                                <TextBlock
                                                    Text="{x:Bind Preview}"
                                                    FontSize="12"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock
                                    x:Name="DetailEmptyText"
                                    Style="{StaticResource BodySecondaryTextStyle}"
                                    VerticalAlignment="Top"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
